---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title="Prerender2 Example | bokken.io" description="Example site for Prerender2 (Speculation Rules API)" />
  </head>
  <body>
    <Header />
    <main>
      <h2>Overview</h2>
      <p>This is an example site for Prerender2.</p>
      <script is:inline>
        const speculationrules = `
            {
                "prerender": [
                    {
                        "source": "list",
                        "urls": ["/too-heavy-image-page/index.html"]
                    }
                ]
            }
        `;
        let state = true;
        document.addEventListener("DOMContentLoaded", () => {
            const container = document.querySelector("#container");

            const $state = document.querySelector("#state");
            $state.innerText = state ? "enabled" : "disabled";
            const $container = document.querySelector("#container");
            const toggle = document.querySelector("#toggle");
            toggle.addEventListener("click", () => {
                state = !state;
                $state.innerText =  state ? "enabled" : "disabled";
                if(state) {
                    // Toggle doesn't work well. So reload.
                    window.location.reload();
                } else {
                    $container.removeChild($container.querySelector("script"))
                }
            })
        });
      </script>
      <div id="container">
          <script type="speculationrules" is:inline>
          {
              "prerender": [
                  {
                      "source": "list",
                      "urls": ["/too-heavy-image-page/index.html"]
                  }
              ]
          }
          </script>
      </div>
      <a href="/too-heavy-image-page/index.html">
          Too heavy website
          <span>(Prerender: <output id="state"></output>)</span>
      </a>

      <br/>
      <br/>
      <button id="toggle">Prerender toggler</button>
    </main>
    <Footer />
  </body>
</html>
