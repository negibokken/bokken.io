---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";

const isDev = import.meta.env.DEV;
const blogHref = isDev ? "/articles" : "https://blog.bokken.io/articles";
const labHref = isDev ? "/lab" : "https://x.bokken.io";
---

<style>
  header {
    margin: 0;
    padding: 0 2em;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    background: linear-gradient(var(--gray-gradient)) no-repeat;
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }
  h2 img {
    vertical-align: middle;
    margin-right: 5px;
  }
  h2#site-title {
    font-size: 1.1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    flex: 1 auto;
    align-items: center;
    justify-content: space-between;
  }
  nav a {
    padding: 0.7em 0.3em;
    color: var(--black);
    border-bottom: 3px solid transparent;
    text-decoration: none;
    font-size: 0.95em;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .social-links,
  .social-links a {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  @media (max-width: 720px) {
    header {
      margin: 0;
      padding: 0 1em;
    }

    span#site-title-text {
      display: none;
    }

    nav {
      display: flex;
      flex: 1;
      align-items: start;
      justify-content: start;
    }

    .social-links {
      display: none;
    }
  }
</style>

<header>
  <nav>
    <a href="/">
      <h2 id="site-title">
        <img
          width="28"
          height="28"
          id="header-icon"
          src="/maru.svg"
          alt="A tiny blue circle icon character"
        />
        <span id="site-title-text">{SITE_TITLE}</span>
      </h2>
    </a>
    <div class="internal-links">
      <HeaderLink href="/">About</HeaderLink>
      <HeaderLink href={blogHref}>Blog</HeaderLink>
      <HeaderLink href={labHref} target="_blank">Lab</HeaderLink>
    </div>
    <div class="social-links">
      <a href="/rss.xml">
        <span class="sr-only">RSS Feed</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="32"
          height="32"
        >
          <circle cx="6.18" cy="17.82" r="2.18" fill="currentColor" />
          <path
            fill="currentColor"
            d="M4 4.44v3.08a12.48 12.48 0 0 1 12.48 12.48h3.08A15.56 15.56 0 0 0 4 4.44z"
          />
          <path
            fill="currentColor"
            d="M4 10.32v3.08a6.6 6.6 0 0 1 6.6 6.6h3.08A9.68 9.68 0 0 0 4 10.32z"
          />
        </svg>
      </a>

      <a href="https://bsky.app/profile/bokken.bsky.social" target="_blank">
        <span class="sr-only">Follow bokken on Bluesky</span>
        <svg
          role="img"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          height="28"
          width="28"
        >
          <desc>Bluesky Streamline Icon: https://streamlinehq.com</desc>
          <title>Bluesky</title>
          <path
            fill="currentColor"
            d="M12 10.8c-1.087 -2.114 -4.046 -6.053 -6.798 -7.995C2.566 0.944 1.561 1.266 0.902 1.565 0.139 1.908 0 3.08 0 3.768c0 0.69 0.378 5.65 0.624 6.479 0.815 2.736 3.713 3.66 6.383 3.364 0.136 -0.02 0.275 -0.039 0.415 -0.056 -0.138 0.022 -0.276 0.04 -0.415 0.056 -3.912 0.58 -7.387 2.005 -2.83 7.078 5.013 5.19 6.87 -1.113 7.823 -4.308 0.953 3.195 2.05 9.271 7.733 4.308 4.267 -4.308 1.172 -6.498 -2.74 -7.078a8.741 8.741 0 0 1 -0.415 -0.056c0.14 0.017 0.279 0.036 0.415 0.056 2.67 0.297 5.568 -0.628 6.383 -3.364 0.246 -0.828 0.624 -5.79 0.624 -6.478 0 -0.69 -0.139 -1.861 -0.902 -2.206 -0.659 -0.298 -1.664 -0.62 -4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"
            stroke-width="1"></path>
        </svg>
      </a>

      <a href="https://github.com/negibokken" target="_blank">
        <span class="sr-only">Go to bokken's GitHub repo</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28"
          ><path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path></svg
        >
      </a>

      <a href="https://twitter.com/bokken_" target="_blank">
        <span class="sr-only">Follow on X (Twitter)</span>
        <svg
          width="22"
          height="22"
          viewBox="0 0 1200 1227"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"
            fill="currentColor"></path>
        </svg>
      </a>
    </div>
  </nav>
</header>
