---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <p>&copy; {currentYear} bokken.io. All rights reserved.</p>
    <p class="links">
      <a href="https://github.com/negibokken" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="separator">|</span>
      <a href="/rss.xml">RSS</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 3rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9em;
  }

  .links {
    margin-top: 0.5rem;
  }

  .separator {
    margin: 0 0.5rem;
  }
</style>
