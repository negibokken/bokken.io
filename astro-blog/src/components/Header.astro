---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/articles/', label: 'Articles' },
  { href: '/tags/', label: 'Tags' },
];
---

<header class="header">
  <div class="container">
    <a href="/" class="logo">bokken.io</a>
    <nav class="nav">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
    margin-bottom: 2rem;
  }

  .header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--color-text);
  }

  .logo:hover {
    text-decoration: none;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    color: var(--color-text-muted);
  }

  .nav-link:hover {
    color: var(--color-text);
  }
</style>
