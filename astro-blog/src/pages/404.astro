---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <div class="not-found">
    <h1>404</h1>
    <p>Page not found</p>
    <a href="/">Back to home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 0;
  }

  .not-found h1 {
    font-size: 6rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .not-found p {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
</style>
